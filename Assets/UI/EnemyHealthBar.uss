.enemy-bar-bg {
    position: absolute;
    width: 30px;
    height: 3px;
    background-color: rgba(38, 38, 38, 217);
    border-radius: 3px;
}

.enemy-bar-fill {
    position: absolute;
    top: 0;
    left: 0;
    bottom: 0;
    width: 100%;
    background-color: rgb(217, 38, 38);
    border-radius: 3px;
}
