  m_Script: {fileID: 11500000, guid: e53d6b19f9bce4499996687ff4c387e8, type: 3}
  m_Name: offer
  m_EditorClassIdentifier: Assembly-CSharp::DialogueSO
  lines:
  - text: "Oh, a traveler. I haven\u2019t seen someone like you in decades. "
  - text: "Come here, I have something you may like\u2026"
  - text: "\u2026it\u2019s a blessing that makes you stronger. "
  - text: Your foes shall run in fear when they see your strength.
  - text: For a small price of 100 coins, I will make it happen.
  choices:
  - text: "Yes. I\u2019ll take it."
    nextDialogue: {fileID: 11400000, guid: 95a2a4ccedfa9456ca3c572095657559, type: 2}
  - text: "I don\u2019t need it. I can handle this on my own."
    nextDialogue: {fileID: 11400000, guid: 00d2a71dd47ec49608c1bffbf1f11e80, type: 2}
