  m_Name: offer
  m_EditorClassIdentifier: Assembly-CSharp::DialogueSO
  lines:
  - text: "Ah, a traveler! Step closer, I have something for you\u2026 "
  - text: "A blessing... It sharpens your strength, steadies your hand\u2026"
  - text: Only 100 coins.
  choices:
  - text: "Yes. I\u2019ll take it."
    nextDialogue: {fileID: 11400000, guid: 95a2a4ccedfa9456ca3c572095657559, type: 2}
  - text: "I don\u2019t need it. I can handle this on my own."
